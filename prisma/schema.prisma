generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id                 String                     @id @default(cuid())
  email              String                     @unique
  name               String
  phone              String?
  location           String?
  avatar_url         String?
  password_hash      String?
  email_verified     Boolean                    @default(false)
  phone_verified     Boolean                    @default(false)
  created_at         DateTime                   @default(now())
  updated_at         DateTime                   @updatedAt
  concierge_requests ConciergeRequest[]
  conversations      Conversation[]
  passes             CustomerEventPass[]
  notification_prefs CustomerNotificationPref[]
  events             Event[]
  hidden_feedback    HiddenFeedback[]
  local_invites      LocalVendorInvite[]
  reviews            Review[]
  contracts          Contract[]          @relation("CustomerContracts")
  favorites          Favorite[]
  payment_schedules  PaymentSchedule[]
  gift_contributions GiftContribution[]
  style_preferences  StyleQuizResponse?
  mood_boards        MoodBoard[]
}

model Vendor {
  id                     String                    @id @default(cuid())
  email                  String                    @unique
  business_name          String
  vendor_type            VendorType
  phone_business         String?
  phone_cell             String?
  address                String?
  city                   String
  country                String
  description            String?
  profile_photo_url      String?
  website                String?
  instagram              String?
  profile_type           String                    @default("BUSINESS")
  first_name             String?
  last_name              String?
  password_hash          String?
  is_active              Boolean                   @default(true)
  is_verified            Boolean                   @default(false)
  tier                   VendorTier                @default(FREE)
  license_number         String?
  health_inspection_date DateTime?
  insurance_number       String?
  email_verified         Boolean                   @default(false)
  phone_verified         Boolean                   @default(false)
  created_at             DateTime                  @default(now())
  updated_at             DateTime                  @updatedAt
  trial_ends_at          DateTime?
  verified_at            DateTime?
  lat                    Float?
  lng                    Float?
  travel_radius_miles    Int                       @default(50)
  conversations          Conversation[]
  matches                Match[]
  menu_items             MenuItem[]
  request_responses      RequestResponse[]
  menu_packages          MenuPackage[]
  past_events            PastEvent[]
  quotes                 Quote[]
  reviews                Review[]
  subscriptions          Subscription[]
  availability           VendorAvailability[]
  credits                VendorCredit?
  documents              VendorDocument[]
  lead                   VendorLead?
  metrics                VendorMetrics[]
  notification_prefs     VendorNotificationPref[]
  operating_schedule     VendorOperatingSchedule[]
  photos                 VendorPhoto[]
  services               VendorService[]
  special_days           VendorSpecialDay[]
  auto_quote_rules       AutoQuoteRule[]
  stations               VendorStation[]
  equipment_listings     VendorEquipment[]
  staff_listings         VendorStaffListing[]
  cancellation_policies  CancellationPolicy[]
  contract_templates     ContractTemplate[]
  contracts              Contract[]          @relation("VendorContracts")
  badges                 VendorBadge[]
  favorited_by           Favorite[]
  instant_book_packages  InstantBookPackage[]
  message_templates      VendorMessageTemplate[]
  calendar_syncs         VendorCalendarSync[]
  pipeline_stages        VendorPipelineEntry[]
  workflows              VendorWorkflow[]
  sustainability_tags    String[]              @default([])
  cancellation_preset_id String?
  cancellation_preset    CancellationPreset?   @relation(fields: [cancellation_preset_id], references: [id])
  custom_station_templates StationTemplate[]   @relation("CustomStationTemplates")
  event_vendors          EventVendor[]
  claimed_external       ExternalVendor?
}

model VendorDocument {
  id         String    @id @default(cuid())
  vendor_id  String
  doc_type   String
  url        String
  expires_at DateTime?
  created_at DateTime  @default(now())
  vendor     Vendor    @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
}

model VendorPhoto {
  id         String   @id @default(cuid())
  vendor_id  String
  url        String
  caption    String?
  is_cover   Boolean  @default(false)
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  vendor     Vendor   @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
}

model VendorService {
  id          String  @id @default(cuid())
  vendor_id   String
  name        String
  description String?
  is_active   Boolean @default(true)
  vendor      Vendor  @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
}

model PastEvent {
  id          String    @id @default(cuid())
  vendor_id   String
  event_type  String
  guest_count Int?
  city        String?
  event_date  DateTime?
  description String?
  photos      String[]
  created_at  DateTime  @default(now())
  vendor      Vendor    @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
}

model Event {
  id                 String               @id @default(cuid())
  customer_id        String
  event_name         String
  event_type         String
  event_date         DateTime
  city               String
  state              String?
  country            String               @default("US")
  metro_city         String?
  metro_state        String?
  venue              String?
  guest_count        Int
  total_budget       Decimal              @db.Decimal(10, 2)
  currency           String               @default("USD")
  total_spent        Decimal              @default(0) @db.Decimal(10, 2)
  checklist_progress Int                  @default(0)
  status             EventStatus          @default(PLANNING)
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt
  invite_image_url   String?
  invite_message     String?
  invite_theme       String?  @default("orange") // preset theme key when no image uploaded
  dietary_options    String[] @default([]) // which meal types to show guests; empty = not configured yet
  collect_allergens  Boolean  @default(false) // whether to ask guests about allergy/dietary needs
  passes             CustomerEventPass[]
  customer           Customer             @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  checklist_items    EventChecklistItem[]
  requests           EventRequest[]
  households         GuestHousehold[]
  local_invites      LocalVendorInvite[]
  sub_events         SubEvent[]
  photos             EventPhoto[]
  contracts          Contract[]
  collaborators      EventCollaborator[]
  coordinator        EventCoordinator?
  payment_schedules  PaymentSchedule[]
  website            EventWebsite?
  gift_registry      GiftRegistry?
  seating_charts     SeatingChart[]
  timeline_entries   EventTimelineEntry[]
  mood_boards        MoodBoard[]
  invitation_design  EventInvitationDesign?
  event_vendors      EventVendor[]
  plan_items         EventPlanItem[]
}

model EventPhoto {
  id         String   @id @default(cuid())
  event_id   String
  url        String
  created_at DateTime @default(now())
  event      Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@index([event_id])
}

model GlobalDish {
  id              String       @id @default(cuid())
  name            String       @unique
  description     String?
  category        MenuCategory
  is_vegetarian   Boolean      @default(false)
  is_vegan        Boolean      @default(false)
  is_jain         Boolean      @default(false)
  is_halal        Boolean      @default(false)
  contains_nuts   Boolean      @default(false)
  contains_gluten Boolean      @default(false)
  contains_dairy  Boolean      @default(false)
  contains_eggs   Boolean      @default(false)
  proteins        String[]     @default([])
  spice_level     String       @default("MEDIUM")
  cuisine_type    String?
  // Rich details
  ingredients     String[]     @default([])   // main ingredients
  history         String?                     // origin story / cultural background
  nutrition       Json?                       // { calories, protein_g, carbs_g, fat_g, fiber_g } per 100g serving
  active          Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
}

model EventChecklistItem {
  id                    String          @id @default(cuid())
  event_id              String
  category              String
  item_name             String
  status                ChecklistStatus @default(PENDING)
  external_vendor_name  String?
  external_vendor_phone String?
  external_vendor_email String?
  quoted_price          Decimal?        @db.Decimal(10, 2)
  quoted_price_type     String?
  finalized_price       Decimal?        @db.Decimal(10, 2)
  finalized_price_type  String?
  deposit_paid          Boolean         @default(false)
  deposit_amount        Decimal?        @db.Decimal(10, 2)
  balance_due           Decimal?        @db.Decimal(10, 2)
  balance_due_date      DateTime?
  notes                 String?
  due_date              DateTime?
  completed_at          DateTime?
  created_at            DateTime        @default(now())
  sub_event_id          String?
  oneseva_vendor_id     String?
  vendor_type           VendorType?
  event                 Event           @relation(fields: [event_id], references: [id], onDelete: Cascade)
  sub_event             SubEvent?       @relation(fields: [sub_event_id], references: [id])

  @@index([sub_event_id])
}

model EventRequest {
  id              String               @id @default(cuid())
  event_id        String
  customer_id     String
  vendor_type     VendorType
  status          RequestStatus        @default(OPEN)
  public_token    String               @unique @default(cuid())
  public_status   String               @default("OPEN")
  service_notes   String?
  created_at      DateTime             @default(now())
  sub_event_id    String?
  menu_preference EventMenuPreference?
  event           Event                @relation(fields: [event_id], references: [id], onDelete: Cascade)
  sub_event       SubEvent?            @relation(fields: [sub_event_id], references: [id])
  matches         Match[]
  responses       RequestResponse[]

  @@index([sub_event_id])
}

model SubEvent {
  id              String                @id @default(cuid())
  event_id        String
  name            String
  event_date      DateTime
  venue           String?
  guest_count     Int?
  budget          Decimal?              @db.Decimal(12, 2)
  currency        String                @default("USD")
  notes           String?
  sort_order      Int                   @default(0)
  created_at      DateTime              @default(now())
  checklist_items EventChecklistItem[]
  requests        EventRequest[]
  invites         GuestSubEventInvite[]
  event           Event                 @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@index([event_id])
}

model GuestHousehold {
  id         String                @id @default(cuid())
  event_id   String
  label      String
  email      String?
  phone      String?
  token      String                @unique @default(cuid())
  declined   Boolean               @default(false)
  created_at DateTime              @default(now())
  event      Event                 @relation(fields: [event_id], references: [id], onDelete: Cascade)
  invites    GuestSubEventInvite[]

  @@index([event_id])
}

model GuestSubEventInvite {
  id           String          @id @default(cuid())
  household_id String
  sub_event_id String
  responded_at DateTime?
  created_at   DateTime        @default(now())
  attendees    GuestAttendee[]
  household    GuestHousehold  @relation(fields: [household_id], references: [id], onDelete: Cascade)
  sub_event    SubEvent        @relation(fields: [sub_event_id], references: [id], onDelete: Cascade)

  @@unique([household_id, sub_event_id])
  @@index([household_id])
  @@index([sub_event_id])
}

model GuestAttendee {
  id           String              @id @default(cuid())
  invite_id    String
  name         String?
  dietary_type GuestDietaryType    @default(NON_VEG)
  allergens    String[]            @default([])
  created_at   DateTime            @default(now())
  invite       GuestSubEventInvite @relation(fields: [invite_id], references: [id], onDelete: Cascade)

  @@index([invite_id])
}

model Match {
  id               String        @id @default(cuid())
  event_request_id String
  vendor_id        String
  vendor_type      VendorType
  score            Int
  rank             Int
  status           MatchStatus   @default(PENDING)
  created_at       DateTime      @default(now())
  viewed_at        DateTime?
  distance_miles   Float?
  conversation     Conversation?
  event_request    EventRequest  @relation(fields: [event_request_id], references: [id], onDelete: Cascade)
  vendor           Vendor        @relation(fields: [vendor_id], references: [id])
  quotes           Quote[]
}

model Quote {
  id                  String          @id @default(cuid())
  match_id            String
  vendor_id           String
  price_per_head      Decimal?        @db.Decimal(10, 2)
  total_estimate      Decimal         @db.Decimal(10, 2)
  currency            String          @default("USD")
  notes               String?
  tasting_offered     Boolean         @default(false)
  tasting_cost        Decimal?        @db.Decimal(10, 2)
  tasting_date        DateTime?
  tasting_location    String?
  status              QuoteStatus     @default(DRAFT)
  expires_at          DateTime?
  created_at          DateTime        @default(now())
  customer_menu_notes String?
  is_menu_finalized   Boolean         @default(false)
  pricing_type        PricingType     @default(PER_HEAD)
  discount_type       String?         // "FLAT" | "PERCENTAGE"
  discount_value      Decimal?        @db.Decimal(10, 2)
  discount_note       String?
  is_auto_generated   Boolean         @default(false)
  match               Match           @relation(fields: [match_id], references: [id], onDelete: Cascade)
  vendor              Vendor          @relation(fields: [vendor_id], references: [id])
  menu_items          QuoteMenuItem[]
  tray_lines          QuoteTrayLine[]
  negotiations        QuoteNegotiation[]
  contract            Contract?
  payment_schedule    PaymentSchedule?
  event_vendor        EventVendor?
}

model QuoteTrayLine {
  id          String  @id @default(cuid())
  quote_id    String
  item_name   String
  serves_note String?
  unit_price  Decimal @db.Decimal(10, 2)
  qty         Int     @default(1)
  line_total  Decimal @db.Decimal(10, 2)
  sort_order  Int     @default(0)
  quote       Quote   @relation(fields: [quote_id], references: [id], onDelete: Cascade)
}

model EventMenuPreference {
  id                  String       @id @default(cuid())
  event_id            String
  caterer_request_id  String       @unique
  menu_mode           MenuMode     @default(CATERER_PROPOSES)
  cuisine_preferences String[]
  service_style       String?
  protein_preference  String?
  soup_salad_count    Int?
  appetizer_count     Int?
  main_count          Int?
  main_veg_count      Int?
  main_non_veg_count  Int?
  bread_count         Int?
  rice_biryani_count  Int?
  dal_count           Int?
  dessert_count       Int?
  live_counter_count  Int?
  beverage_count      Int?
  is_vegetarian       Boolean      @default(false)
  is_vegan            Boolean      @default(false)
  is_jain             Boolean      @default(false)
  is_halal            Boolean      @default(false)
  is_kosher           Boolean      @default(false)
  nut_free            Boolean      @default(false)
  gluten_free         Boolean      @default(false)
  dairy_free          Boolean      @default(false)
  egg_free            Boolean      @default(false)
  shellfish_free      Boolean      @default(false)
  soy_free            Boolean      @default(false)
  special_notes       String?
  pricing_preference       String       @default("NO_PREFERENCE")
  customer_tray_requests   Json?
  selected_dishes          Json?
  custom_dish_categories   Json?  // Record<dishName, categoryKey> for custom dishes not in library
  // Logistics & setup
  delivery_required        Boolean      @default(false)
  setup_required           Boolean      @default(false)
  serving_staff_required   Boolean      @default(false)
  equipment_required       Boolean      @default(false)
  labels_required          Boolean      @default(false)
  updated_at               DateTime     @default(now()) @updatedAt
  change_summary           String?      // Human-readable note of what changed on last update
  caterer_request          EventRequest @relation(fields: [caterer_request_id], references: [id], onDelete: Cascade)
}

model RequestResponse {
  id               String       @id @default(cuid())
  event_request_id String
  vendor_id        String?
  name             String
  phone            String?
  pitch            String
  price_note       String?
  portfolio_url      String?
  email              String?
  quote_token        String?      @unique @default(cuid())
  quoted_price       Decimal?
  price_unit         String?
  what_includes      String?
  service_details    String?
  availability_note  String?
  quote_submitted_at DateTime?
  status             String       @default("PENDING")
  external_vendor_id String?
  created_at       DateTime     @default(now())
  event_request    EventRequest @relation(fields: [event_request_id], references: [id], onDelete: Cascade)
  vendor           Vendor?      @relation(fields: [vendor_id], references: [id], onDelete: SetNull)
  external_vendor  ExternalVendor? @relation(fields: [external_vendor_id], references: [id])

  @@index([event_request_id])
}

model ServiceConfig {
  id            String  @id @default(cuid())
  vendor_type   String  @unique
  is_enabled    Boolean @default(false)
  sort_order    Int     @default(0)
  label         String
  icon          String
  service_class String  @default("BUSINESS")
}

model MenuPackage {
  id               String            @id @default(cuid())
  vendor_id        String
  name             String
  description      String?
  price_per_head   Decimal           @db.Decimal(10, 2)
  currency         String            @default("USD")
  min_guests       Int?
  max_guests       Int?
  cuisine_type     String?
  is_vegetarian    Boolean           @default(false)
  is_vegan         Boolean           @default(false)
  is_jain          Boolean           @default(false)
  is_halal         Boolean           @default(false)
  nut_free         Boolean           @default(false)
  gluten_free      Boolean           @default(false)
  dairy_free       Boolean           @default(false)
  includes_service Boolean           @default(false)
  includes_setup   Boolean           @default(false)
  is_active        Boolean           @default(true)
  created_at       DateTime          @default(now())
  vendor           Vendor            @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
  items            MenuPackageItem[]
  auto_quote_rules AutoQuoteRule[]
}

model MenuItem {
  id                   String            @id @default(cuid())
  vendor_id            String
  name                 String
  description          String?
  category             MenuCategory
  is_vegetarian        Boolean           @default(false)
  is_vegan             Boolean           @default(false)
  is_jain              Boolean           @default(false)
  is_halal             Boolean           @default(false)
  is_kosher            Boolean           @default(false)
  contains_nuts        Boolean           @default(false)
  contains_gluten      Boolean           @default(false)
  contains_dairy       Boolean           @default(false)
  contains_eggs        Boolean           @default(false)
  contains_soy         Boolean           @default(false)
  contains_shellfish   Boolean           @default(false)
  spice_level          SpiceLevel        @default(MEDIUM)
  is_active            Boolean           @default(true)
  calories_per_serving Int?
  carbs_g              Decimal?          @db.Decimal(6, 1)
  fat_g                Decimal?          @db.Decimal(6, 1)
  ingredients          String[]
  is_global            Boolean           @default(false)
  pending_review       Boolean           @default(false)
  prep_notes           String?
  protein_g            Decimal?          @db.Decimal(6, 1)
  proteins             String[]
  serves_description   String?
  vendor               Vendor            @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
  packages             MenuPackageItem[]
  quote_items          QuoteMenuItem[]
}

model MenuPackageItem {
  id           String      @id @default(cuid())
  package_id   String
  menu_item_id String
  is_optional  Boolean     @default(false)
  sort_order   Int         @default(0)
  menu_item    MenuItem    @relation(fields: [menu_item_id], references: [id], onDelete: Cascade)
  package      MenuPackage @relation(fields: [package_id], references: [id], onDelete: Cascade)
}

model QuoteMenuItem {
  id                     String       @id @default(cuid())
  quote_id               String
  menu_item_id           String?
  item_name              String
  category               MenuCategory
  is_vegetarian          Boolean      @default(false)
  is_jain                Boolean      @default(false)
  is_halal               Boolean      @default(false)
  contains_nuts          Boolean      @default(false)
  contains_gluten        Boolean      @default(false)
  contains_dairy         Boolean      @default(false)
  is_optional            Boolean      @default(false)
  notes                  String?
  sort_order             Int          @default(0)
  is_removed_by_customer Boolean      @default(false)
  added_by_customer      Boolean      @default(false)
  description            String?
  menu_item              MenuItem?    @relation(fields: [menu_item_id], references: [id])
  quote                  Quote        @relation(fields: [quote_id], references: [id], onDelete: Cascade)
}

model HiddenFeedback {
  id                    String   @id @default(cuid())
  vendor_id             String
  customer_id           String
  event_request_id      String
  match_id              String
  would_recommend       Boolean
  communication_score   Int
  professionalism_score Int
  quote_accuracy        Int
  overall_experience    Int
  notes                 String?
  booked_offline        Boolean  @default(false)
  created_at            DateTime @default(now())
  customer              Customer @relation(fields: [customer_id], references: [id])
}

model Review {
  id                  String    @id @default(cuid())
  vendor_id           String
  customer_id         String
  event_id            String
  overall_rating      Int
  food_quality_rating Int?
  service_rating      Int?
  value_rating        Int?
  title               String?
  body                String?
  event_type          String?
  event_date          DateTime?
  is_verified         Boolean   @default(false)
  vendor_reply        String?
  is_published        Boolean   @default(true)
  created_at          DateTime  @default(now())
  customer            Customer  @relation(fields: [customer_id], references: [id])
  vendor              Vendor    @relation(fields: [vendor_id], references: [id])
}

model Conversation {
  id              String    @id @default(cuid())
  match_id        String    @unique
  customer_id     String
  vendor_id       String
  last_message_at DateTime?
  is_archived     Boolean   @default(false)
  created_at      DateTime  @default(now())
  customer        Customer  @relation(fields: [customer_id], references: [id])
  match           Match     @relation(fields: [match_id], references: [id], onDelete: Cascade)
  vendor          Vendor    @relation(fields: [vendor_id], references: [id])
  messages        Message[]
}

model Message {
  id              String       @id @default(cuid())
  conversation_id String
  sender_id       String
  sender_type     SenderType
  body            String
  is_read         Boolean      @default(false)
  created_at      DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
}

model VendorAvailability {
  id           String   @id @default(cuid())
  vendor_id    String
  date         DateTime @db.Date
  is_available Boolean  @default(false)
  reason       String?
  notes        String?
  created_at   DateTime @default(now())
  vendor       Vendor   @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  @@unique([vendor_id, date])
}

model VendorOperatingSchedule {
  id          String  @id @default(cuid())
  vendor_id   String
  day_of_week String
  is_open     Boolean @default(true)
  opens_at    String?
  closes_at   String?
  notes       String?
  vendor      Vendor  @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  @@unique([vendor_id, day_of_week])
}

model VendorSpecialDay {
  id         String   @id @default(cuid())
  vendor_id  String
  date       DateTime @db.Date
  is_open    Boolean  @default(false)
  opens_at   String?
  closes_at  String?
  reason     String?
  created_at DateTime @default(now())
  vendor     Vendor   @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  @@unique([vendor_id, date])
}

model VendorMetrics {
  id                  String     @id @default(cuid())
  vendor_id           String
  vendor_type         VendorType
  period              DateTime   @db.Date
  lead_count          Int        @default(0)
  quote_rate          Decimal    @default(0) @db.Decimal(5, 4)
  shortlist_rate      Decimal    @default(0) @db.Decimal(5, 4)
  avg_response_hrs    Decimal    @default(0) @db.Decimal(6, 2)
  avg_rating          Decimal    @default(0) @db.Decimal(3, 2)
  booking_rate        Decimal    @default(0) @db.Decimal(5, 4)
  hidden_feedback_avg Decimal    @default(0) @db.Decimal(3, 2)
  vendor              Vendor     @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  @@unique([vendor_id, period])
}

model Subscription {
  id                     String     @id @default(cuid())
  vendor_id              String
  tier                   VendorTier
  stripe_subscription_id String?    @unique
  status                 String
  current_period_end     DateTime?
  leads_this_month       Int        @default(0)
  leads_limit            Int        @default(3)
  created_at             DateTime   @default(now())
  vendor                 Vendor     @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
}

model CustomerEventPass {
  id                       String     @id @default(cuid())
  customer_id              String
  event_id                 String
  stripe_payment_intent_id String?
  amount                   Decimal    @db.Decimal(10, 2)
  currency                 String     @default("USD")
  status                   PassStatus @default(ACTIVE)
  purchased_at             DateTime   @default(now())
  expires_at               DateTime
  customer                 Customer   @relation(fields: [customer_id], references: [id])
  event                    Event      @relation(fields: [event_id], references: [id])
}

model ExternalVendor {
  id              String      @id @default(cuid())
  place_id        String      @unique
  name            String
  address         String
  city            String
  state           String?
  country         String      @default("US")
  lat             Float?
  lng             Float?
  phone           String?
  website         String?
  rating          Float?
  total_ratings   Int         @default(0)
  price_level     Int?        // Google 0-4 scale
  vendor_type     VendorType
  photo_urls      String[]    @default([])
  maps_url        String
  business_hours  Json?       // { monday: "9:00-17:00", ... }
  description     String?
  is_active       Boolean     @default(true)
  claimed_by_vendor_id String? @unique
  claimed_at      DateTime?
  fetched_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  claimed_by      Vendor?     @relation(fields: [claimed_by_vendor_id], references: [id])
  invites         LocalVendorInvite[]
  quote_requests  RequestResponse[]

  @@index([city, vendor_type])
  @@index([vendor_type])
}

model LocalVendorInvite {
  id            String   @id @default(cuid())
  place_id      String
  business_name String
  address       String?
  phone         String?
  website       String?
  rating        Float?
  vendor_type   String
  city          String
  customer_id   String
  event_id      String
  external_vendor_id String?
  created_at    DateTime @default(now())
  customer      Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  event         Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  external_vendor ExternalVendor? @relation(fields: [external_vendor_id], references: [id])

  @@unique([place_id, customer_id, event_id])
}

model CustomerNotificationPref {
  id          String              @id @default(cuid())
  customer_id String
  channel     NotificationChannel
  event_type  String
  is_enabled  Boolean             @default(true)
  updated_at  DateTime            @updatedAt
  customer    Customer            @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@unique([customer_id, channel, event_type])
}

model VendorNotificationPref {
  id         String              @id @default(cuid())
  vendor_id  String
  channel    NotificationChannel
  event_type String
  is_enabled Boolean             @default(true)
  updated_at DateTime            @updatedAt
  vendor     Vendor              @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  @@unique([vendor_id, channel, event_type])
}

model VendorCredit {
  id           String              @id @default(cuid())
  vendor_id    String              @unique
  balance      Int                 @default(0)
  total_bought Int                 @default(0)
  total_spent  Int                 @default(0)
  created_at   DateTime            @default(now())
  updated_at   DateTime            @updatedAt
  transactions CreditTransaction[]
  vendor       Vendor              @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id          String       @id @default(cuid())
  credit_id   String
  amount      Int
  type        CreditTxType
  description String?
  reference   String?
  created_at  DateTime     @default(now())
  credit      VendorCredit @relation(fields: [credit_id], references: [id], onDelete: Cascade)
}

model ConciergeRequest {
  id           String          @id @default(cuid())
  customer_id  String
  event_date   DateTime?
  event_type   String?
  guest_count  Int?
  budget       String?
  city         String
  vendor_types String[]
  notes        String?
  status       ConciergeStatus @default(NEW)
  admin_notes  String?
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt
  customer     Customer        @relation(fields: [customer_id], references: [id], onDelete: Cascade)
}

model VendorLead {
  id               String           @id @default(cuid())
  place_id         String?          @unique
  business_name    String
  vendor_type      VendorType?
  address          String?
  city             String
  state            String?
  phone            String?
  email            String?
  website          String?
  maps_url         String?
  rating           Float?
  total_ratings    Int              @default(0)
  opening_hours    String?
  status           VendorLeadStatus @default(NEW)
  notes            String?
  contacted_at     DateTime?
  invited_at       DateTime?
  joined_vendor_id String?          @unique
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  invites          VendorInvite[]
  joined_vendor    Vendor?          @relation(fields: [joined_vendor_id], references: [id])
}

model VendorInvite {
  id         String     @id @default(cuid())
  lead_id    String
  token      String     @unique @default(cuid())
  email      String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime   @default(now())
  lead       VendorLead @relation(fields: [lead_id], references: [id], onDelete: Cascade)
}

model VerificationOtp {
  id         String   @id @default(cuid())
  target     String   // email address or phone number
  type       String   // "email" | "phone"
  role       String   // "customer" | "vendor"
  code       String
  attempts   Int      @default(0)
  used       Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([target, type])
}

